# Local test environment — safe to commit (localhost only, no secrets).
# Used by vitest (via vitest.config.ts loadEnv) and drizzle-kit push:test.
DATABASE_URL=postgresql://localhost:5432/remi_test
# Tests share one postgres-js client across all integration files; cap the
# pool small so we don't run into "too many clients already" when the
# suite is large.
DATABASE_POOL_MAX=5

# Stub credentials for services we mock in tests. Real values never used —
# but the singletons throw at module load if these are missing.
STRIPE_SECRET_KEY=sk_test_stub_for_vitest_never_called
RESEND_API_KEY=re_test_stub_for_vitest_never_called
EMAIL_FROM=Remi Test <noreply@example.test>
FEEDBACK_EMAIL=feedback@example.test
NEXTAUTH_SECRET=test-secret-not-used
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
